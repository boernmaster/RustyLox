# RustyLox environment variables
# Copy this file to .env and fill in the values.
#
# Generate JWT_SECRET with:
#   openssl rand -hex 32

# Required: secret used to sign JWTs (min 32 chars)
JWT_SECRET=

# Required on first boot to create the admin user (min 8 chars).
# Remove or leave unset after the admin user has been created.
ADMIN_PASSWORD=
